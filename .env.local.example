# Copy this file to .env.local and fill in values from your Supabase project.
# Supabase Dashboard → Project Settings → Data API / API Keys

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only key — NEVER expose to the browser. Used for admin actions
# (creating agents, auto-emailing bookkeeping). Keep out of git (.env.local is gitignored).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gmail / Google Workspace SMTP (for sending documents to bookkeeping + alerts).
# GMAIL_USER = a TMT Workspace address; GMAIL_APP_PASSWORD = a 16-char App Password
# (Google Account → Security → 2-Step Verification → App passwords).
GMAIL_USER=you@themcbrideteam.com
GMAIL_APP_PASSWORD=your-16-char-app-password
BOOKKEEPING_EMAIL=bookkeeping@c21magnolia.com

# Where agent-action notifications go (Zillow account confirmed, lenders submitted).
NOTIFY_EMAIL=noah@themcbrideteam.com

# Restrict Google sign-in to these Workspace domains (comma-separated). Enforced
# server-side in the auth callback. Leave unset to default to themcbrideteam.com.
ALLOWED_EMAIL_DOMAINS=themcbrideteam.com

# Google Drive auto-filing (optional — leave blank to keep Supabase + email only).
# Uses OAuth (service-account keys are blocked by the Workspace org policy):
#  1. Google Cloud Console → enable Drive API; OAuth consent screen = Internal.
#  2. Credentials → Create OAuth client → type "Desktop app". Copy id + secret below.
#  3. Run: node scripts/get-drive-token.mjs  → paste the printed refresh token below.
#  4. Create a Drive/Shared Drive folder; put its ID (from the URL) in GDRIVE_PARENT_FOLDER_ID.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GDRIVE_PARENT_FOLDER_ID=

# --- Sprint 2 automations (all optional; features no-op until set) ---
# Slack incoming webhook for the onboarding channel (api.slack.com/apps →
# Incoming Webhooks → pick #agent-onboarding). Powers real-time pings +
# the weekday digest + Noah's Monday one-pager.
SLACK_WEBHOOK_URL=

# Follow Up Boss API key (FUB → Admin → API). Enables the nightly conversation
# sync. When set, ALSO set NEXT_PUBLIC_FUB_SYNC=1 so agents stop manual logging.
FUB_API_KEY=
NEXT_PUBLIC_FUB_SYNC=
